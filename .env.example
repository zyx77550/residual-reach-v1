# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe
STRIPE_SECRET_KEY=sk_test_REMPLACER
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACER

# Stripe Price IDs (créer dans Stripe Dashboard)
STRIPE_PRICE_STARTER=price_REMPLACER
STRIPE_PRICE_PRO=price_REMPLACER
STRIPE_PRICE_AGENCY=price_REMPLACER

# LLM Providers
GROQ_API_KEY=gsk_REMPLACER
MISTRAL_API_KEY=REMPLACER
